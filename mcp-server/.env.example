# This server's public URL (no trailing slash)
SERVER_URL=https://mcp.qrsimplified.com

# Your existing API Gateway base URL (no trailing slash)
API_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/prod/v2

# Cognito hosted domain (no trailing slash)
# Found in AWS Console → Cognito → User Pools → App Integration → Domain
COGNITO_DOMAIN=https://your-app-123456789.auth.us-east-1.amazoncognito.com

# Cognito app client ID and secret
# Found in AWS Console → Cognito → User Pools → App Integration → App clients
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_CLIENT_SECRET=your_cognito_client_secret

# Credentials Claude/ChatGPT use when calling /oauth/token on THIS server
# You define these — make them strong random strings
MCP_CLIENT_ID=qrsimplified-mcp
MCP_CLIENT_SECRET=generate_a_strong_secret_here

PORT=3000
